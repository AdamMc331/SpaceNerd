{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  packageRules: [
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      automerge: true,
    },
    {
      matchFileNames: [
        '**/android_ui_tests.yml',
      ],
      matchPackageNames: [
        'macos',
      ],
      enabled: false,
    },
  ],
  platformAutomerge: true,
  ignorePresets: [
    'workarounds:javaLTSVersions',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/\\.java-version$/',
      ],
      matchStrings: [
        '(?<currentValue>.*)\\n',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      extractVersionTemplate: '^(?<version>\\d+)',
    },
  ],
}
